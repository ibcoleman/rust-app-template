# Copy to .env and source it before running `just test-integration`:
#
#   cp .env.example .env
#   set -a; source .env; set +a
#   just test-integration
#
# .env is gitignored; .env.example is the committed template.
# The app itself does NOT read .env — it reads env vars directly
# (in k8s they come from the Deployment manifest). This file exists
# solely to make local `just test-integration` runs ergonomic.

# Postgres connection for integration tests.
# Matches the local kind-cluster postgres: credentials are hardcoded in
# k8s/base/postgres-statefulset.yaml, and the Tiltfile port-forwards
# 5432 while `just dev` is running — so tests reach the cluster DB via
# localhost. If you run postgres some other way, point this at it.
DATABASE_URL=postgres://app:app@localhost:5432/app

# --- Optional ---

# Address the app binds to outside k8s. Irrelevant inside the cluster
# (the Deployment sets this explicitly).
BIND_ADDR=127.0.0.1:8080

# tracing_subscriber filter. Try `debug` or `rust_app_template=debug,info`
# for more detail without a firehose.
RUST_LOG=info
